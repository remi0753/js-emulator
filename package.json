{
  "name": "js-emulator",
  "version": "0.1.0",
  "description": "TypeScript で実装する仮想レジスタマシン CPU と、その上で動くプリエンプティブ・マルチタスク OS",
  "type": "module",
  "scripts": {
    "test": "node --test --experimental-strip-types",
    "typecheck": "tsc --noEmit",
    "build:img": "node tools/mkimg.ts",
    "boot": "node tools/boot.ts",
    "demo": "node demo/multitask.ts",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/node": "^24.13.2",
    "typescript": "^5.7.0"
  },
  "license": "MIT"
}
